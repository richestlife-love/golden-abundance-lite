# Copy to `.env` and fill in values for local overrides.

# SQLAlchemy URL for the app database (psycopg3 driver).
DATABASE_URL=postgresql+psycopg://app:app@localhost:5432/app

# Alembic-only override. Set when the runtime role is restricted
# (e.g. Supabase: runtime uses `app_runtime`, migrations use `postgres`).
# MIGRATION_DATABASE_URL=

# Supabase project base URL. Required for prod and local dev sign-in
# (backend fetches JWKS here).
SUPABASE_URL=

# Runtime environment: one of `dev`, `test`, `prod`.
APP_ENV=dev

# Sentry error reporting. Optional — when unset, sentry_sdk.init() is skipped.
# SENTRY_DSN=
# APP_RELEASE=${{RAILWAY_GIT_COMMIT_SHA}}

# Rate limiting. CI sets this to 1 in tests/conftest.py so idempotent-loop
# tests don't trip the limiter.
RATE_LIMIT_DISABLED=0
