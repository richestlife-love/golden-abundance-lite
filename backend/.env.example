# Copy to `.env` and fill in values for local overrides.
# pydantic-settings loads `.env` on `Settings()` construction; see src/backend/config.py.

# SQLAlchemy URL for the app database (psycopg3 driver).
DATABASE_URL=postgresql+psycopg://app:app@localhost:5432/app

# Optional: URL used *only* by Alembic migrations. Set this when the runtime
# role is restricted and migrations need a privileged role (e.g. Supabase:
# DATABASE_URL=.../app_runtime, MIGRATION_DATABASE_URL=.../postgres).
# Leave unset to use DATABASE_URL for both runtime and migrations.
# MIGRATION_DATABASE_URL=

# Supabase project base URL. Required when APP_ENV=prod. Leave unset for local
# dev + tests; they don't talk to Supabase.
SUPABASE_URL=https://your-project-ref.supabase.co

# Audience claim enforced on incoming JWTs. Defaults to Supabase's "authenticated".
SUPABASE_JWT_AUD=authenticated

# Comma-separated list of allowed CORS origins.
CORS_ORIGINS=http://localhost:5173

# Runtime environment: one of `dev`, `test`, `prod`.
APP_ENV=dev

# Sentry error reporting. Optional — when unset, sentry_sdk.init() is skipped
# and no telemetry traffic is produced.
# SENTRY_DSN=
# APP_RELEASE=

# Rate limiting (H1). Leave unset / empty for prod; CI sets this to 1
# in tests/conftest.py so idempotent-loop tests don't trip the limiter.
# RATE_LIMIT_DISABLED=0
