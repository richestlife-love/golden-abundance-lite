default: serve

# Run full CI (install, format, typecheck + bundle). Mirrors backend's `ci`.
ci:
    pnpm install
    pnpm run format
    pnpm run build

# Install frontend deps (idempotent; uses pnpm-lock.yaml when present).
install:
    pnpm install

# Run the Vite dev server on http://localhost:5173
serve: install
    pnpm run dev

# Type-check and build the production bundle into frontend/dist
build: install
    pnpm run build

# Format frontend sources with Prettier
fmt: install
    pnpm run format

# Expose local port 5173 (https) via a reserved ngrok hostname
tunnel:
    ngrok http --url=subvitalized-occupative-katelyn.ngrok-free.dev --scheme=https 5173
