set dotenv-filename := ".env.local"

# Run full CI (install, lint, format, typecheck + bundle). Mirrors backend's `ci`.
ci:
    pnpm install
    pnpm run lint
    pnpm run format
    pnpm run build

# Run the Vite dev server on http://localhost:5173
dev:
    pnpm run dev

# Expose local port 5173 (https) via the ngrok host in .env.local
tunnel:
    ngrok http --url=$VITE_ALLOWED_HOSTS --scheme=https 5173
