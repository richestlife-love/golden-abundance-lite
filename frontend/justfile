set dotenv-filename := ".env.local"

# Run full CI (install, lint, format, typecheck, tests, bundle).
ci:
    pnpm install
    pnpm run lint
    pnpm run format
    pnpm run typecheck
    pnpm run test
    pnpm run build

# Run the Vite dev server (default port 5173; override via VITE_PORT in .env.local).
dev:
    pnpm run dev

# Expose the local dev server via ngrok (uses NGROK_HOST + VITE_PORT from .env.local).
tunnel:
    ngrok http ${NGROK_HOST:+--url=$NGROK_HOST} ${VITE_PORT:-5173}
