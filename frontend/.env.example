# Copy to `.env.local` and fill in values for local overrides.

# Backend API origin for Vite's /api proxy.
VITE_API_BASE_URL=http://localhost:8000

# Dev server port.
VITE_PORT=5173

# Tunnel hosts for Vite's `allowedHosts` (e.g. your-tunnel-host.ngrok-free.dev).
# VITE_ALLOWED_HOSTS=

# ngrok hostname used by `just tunnel` (e.g. your-tunnel-host.ngrok-free.dev).
# NGROK_HOST=

# Supabase project URL (https://<ref>.supabase.co).
VITE_SUPABASE_URL=

# Supabase publishable key (format: sb_publishable_...). From Supabase → Settings → API.
VITE_SUPABASE_PUBLISHABLE_KEY=
